<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow execution of subprocesses -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
    
    <!-- Allow access to user-selected files -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    
    <!-- Allow access to application data -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>com.guojc.space-app</string>
    </array>
    
    <!-- Allow execution of other applications (Chrome) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    
    <!-- Allow debugging (needed for process monitoring) -->
    <key>com.apple.security.cs.debugger</key>
    <true/>
    
    <!-- Allow reading system information -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    
    <!-- Allow dyld environment variables -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    
    <!-- Disable library validation to allow loading system libraries -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    
    <!-- Allow access to downloads folder -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
</dict>
</plist>
